APP_NAME=Smart Recruitment & HR Platform
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

SECRET_KEY=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_ALGORITHM=HS256

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=25

AISTUDIO_API_KEY=
AISTUDIO_MODEL=gemini-1.5-flash
AISTUDIO_TIMEOUT_SECONDS=25
AI_DEFAULT_PASS_SCORE=60

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_cv_service
REDIS_URL=redis://redis:6379/0

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

STORAGE_PROVIDER=local
UPLOAD_DIR=uploads
AVATAR_DIR=uploads/avatars
CV_DIR=uploads/cvs
MAX_FILE_SIZE_MB=10

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/linkedin/callback
LINKEDIN_FRONTEND_CALLBACK_URI=http://localhost:5173/oauth/linkedin/callback
LINKEDIN_OAUTH_SCOPE=openid profile email

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback
GOOGLE_FRONTEND_CALLBACK_URI=http://localhost:5173/oauth/google/callback
GOOGLE_OAUTH_SCOPE=openid email profile

GMAIL_SENDER_EMAIL=
GMAIL_APP_PASSWORD=

ENABLE_SOCIAL_AUTH=true

RATE_LIMIT_DEFAULT=100/minute
