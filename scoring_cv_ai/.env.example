APP_NAME=CV Scoring AI Service
APP_ENV=development
APP_DEBUG=true
SERVICE_PORT=5005

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/%2F
RABBITMQ_EXCHANGE=recruitment.events
RABBITMQ_REQUEST_ROUTING_KEY=cv.scoring.request
RABBITMQ_RESULT_ROUTING_KEY=cv.scoring.result
RABBITMQ_FAILED_ROUTING_KEY=cv.scoring.failed
RABBITMQ_REQUEST_QUEUE=cv.scoring.request.queue
RABBITMQ_PREFETCH_COUNT=4
RABBITMQ_RECONNECT_DELAY_SECONDS=3
ENABLE_RABBITMQ_CONSUMER=true

CV_BASE_DIR=/app
CV_ALLOWED_ROOTS=/app/uploads/cvs,/data/uploads/cvs

AISTUDIO_API_KEY=
AISTUDIO_MODEL=gemini-1.5-flash
AISTUDIO_TIMEOUT_SECONDS=25
